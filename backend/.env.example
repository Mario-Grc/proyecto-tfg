PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
LLM_API_ENDPOINT=http://127.0.0.1:1234/v1/chat/completions
LLM_MODEL_NAME=local-model
ENABLE_TOOL_CALLING=true
TOOL_CALL_MAX_ROUNDS=3
CODE_RUNNER_TIMEOUT_MS=5000
CODE_RUNNER_MAX_CODE_CHARS=12000

DATA_DIR=./data
DB_FILE_NAME=quackcode.db

# Web search
ENABLE_MCP_WEB_SEARCH=false
MCP_WEB_SEARCH_TIMEOUT_MS=15000
TAVILY_MCP_ENDPOINT=https://mcp.tavily.com/mcp
TAVILY_MCP_TOOL_NAME=tavily-search
TAVILY_API_KEY=
